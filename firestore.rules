rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Master Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers Globais
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper de Admin - e-mail do gestor do Almoxarifado Ventisol
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "almoxarifado.sc@ventisol.com.br" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 2. Validação Blueprint para Ordens de Produção (Op)
    function isValidOp(data) {
      return data.codigo is string && data.codigo.size() > 0 && data.codigo.size() <= 64 &&
             data.descricao is string && data.descricao.size() > 0 && data.descricao.size() <= 256 &&
             data.quantidade is int && data.quantidade > 0 &&
             data.status is string && (data.status == "pendente" || data.status == "separando" || data.status == "concluido" || data.status == "cancelada") &&
             data.sequencia is int && data.sequencia >= 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /ops/{opId} {
      allow read: if isSignedIn();
      
      // Criar OPs: admin ou logado
      allow create: if isSignedIn() && isValidOp(incoming()) && (
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time
      );

      // Atualizar OPs:
      allow update: if isSignedIn() && isValidOp(incoming()) && (
        // Se for admin, pode editar qualquer campo livremente
        isAdmin() ||
        // Se for operador comum:
        (
          // Impedir se a OP existente já foi finalizada ou cancelada (Trava de Estado Terminal)
          existing().status != "cancelada" && existing().status != "concluido" &&
          // Impedir alterações no createdAt e sequencia originais de separação
          incoming().createdAt == existing().createdAt &&
          incoming().sequencia == existing().sequencia &&
          incoming().updatedAt == request.time &&
          // Só pode salvar modificações de progresso (status mudando, ou itens mudando)
          incoming().diff(existing()).affectedKeys().hasAny(['status', 'itens', 'updatedAt'])
        )
      );

      allow delete: if isAdmin();
    }

    // 3. Validação Blueprint para Cargas de Docas (DockLoad)
    function isValidDockLoad(data) {
      return data.fornecedor is string && data.fornecedor.size() > 0 && data.fornecedor.size() <= 128 &&
             data.material is string && data.material.size() > 0 && data.material.size() <= 128 &&
             data.placa is string && data.placa.size() > 0 && data.placa.size() <= 16 &&
             data.status is string && (data.status == "aguardando" || data.status == "descarregando" || data.status == "concluido") &&
             data.doca is string && data.doca.size() > 0 && data.doca.size() <= 64 &&
             data.tempoEstimado is int && data.tempoEstimado >= 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /dock_loads/{loadId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isValidDockLoad(incoming()) && (
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time
      );

      allow update: if isSignedIn() && isValidDockLoad(incoming()) && (
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        (isAdmin() || incoming().diff(existing()).affectedKeys().hasAny(['status', 'doca', 'updatedAt']))
      );

      allow delete: if isAdmin();
    }
  }
}
