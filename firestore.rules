rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function getUserData() { return get(/databases/$(database)/documents/profiles/$(request.auth.uid)); }
    function isApproved() { return isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && getUserData().data.status == 'APPROVED'; }
    function isAdmin() { 
      let userEmail = request.auth.token.get('email', '').lower();
      let isBootstrap = userEmail == 'almoxarifado.sc@ventisol.com.br' || 
                        userEmail == 'espinmais@gmail.com';
      return isSignedIn() && (isBootstrap || (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && getUserData().data.get('is_admin', false) == true));
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Phase 2: Helper constraints
    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.status in ['PENDING', 'APPROVED', 'REJECTED'];
    }

    // 1. Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isApproved() || isAdmin());
      allow list: if isApproved() || isAdmin();
      allow create: if isSignedIn() && (
        (isOwner(userId) && isValidProfile(incoming()) && incoming().status == 'PENDING')
        || isAdmin()
      );
      allow update: if (isSignedIn() && isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'category', 'allowed_groups']))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Operations
    function isValidOperation(data) {
      return data.keys().hasAll(['id', 'line', 'quantity', 'date'])
        && data.id is string && data.line is string && data.quantity is number;
    }
    match /operations/{opId} {
      allow read: if isApproved() || isAdmin();
      allow create: if isAdmin() && isValidOperation(incoming());
      allow update: if (isAdmin() || (isApproved() && incoming().diff(existing()).affectedKeys().hasOnly(['steps', 'progress', 'is_completed'])))
        && isValidOperation(incoming());
      allow delete: if isAdmin();
    }

    // 3. News Posts
    match /news_posts/{newsId} {
      allow read: if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // 4. Production Lines
    match /production_lines/{lineId} {
      allow read: if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // 5. Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Suppliers & Load Types
    match /suppliers/{sId} {
      allow read: if isApproved() || isAdmin();
      allow write: if isAdmin();
    }
    match /load_types/{tId} {
      allow read: if isApproved() || isAdmin();
      allow write: if isAdmin();
    }

    // 7. Receipts
    match /receipts/{rId} {
      allow read: if isApproved() || isAdmin();
      allow create: if (isApproved() && incoming().author_id == request.auth.uid) || isAdmin();
      allow update: if (isApproved() || isAdmin()) && (
        isAdmin() || 
        (existing().status != 'Concluído' && (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updated_at', 'updated_by_name', 'status_history', 'divergence_observation', 'divergence_photo_url'])))
      );
      allow delete: if isAdmin();
    }

    // 8. Purchase Orders
    match /purchase_orders/{pId} {
      allow read: if isApproved() || isAdmin();
      allow create: if isAdmin();
      allow update: if (isApproved() || isAdmin()) && (
        isAdmin() ||
        (existing().status != 'Baixada' && (
          // Action: Assign
          (incoming().diff(existing()).affectedKeys().hasOnly(['assigned_users'])) ||
          // Action: Confer
          (incoming().diff(existing()).affectedKeys().hasOnly(['items', 'conferred_by_id', 'conferred_by_name', 'conferred_at', 'status', 'pis', 'observation', 'photos'])) ||
          // Action: Sign
          (incoming().diff(existing()).affectedKeys().hasOnly(['signature_url', 'is_signed', 'signed_at', 'signed_by_name']))
        ))
      );
      allow delete: if isAdmin();
    }

  }
}
