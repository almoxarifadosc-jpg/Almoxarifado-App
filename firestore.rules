rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives (Hardened for cost optimization)
    function isSignedIn() { return request.auth != null; }
    function queryExisting() { return resource.data; }
    function incoming() { return request.resource.data; }
    
    // Check approval without redundant get() calls in loops
    // isApproved() will be used sparingly
    function isApproved() { 
      return isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) 
             && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.status == 'APPROVED'; 
    }
    
    function isAdmin() { 
      let userEmail = request.auth.token.get('email', '').lower();
      let isBootstrap = userEmail == 'almoxarifado.sc@ventisol.com.br' || 
                        userEmail == 'espinmais@gmail.com';
      return isSignedIn() && (isBootstrap || (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('is_admin', false) == true));
    }

    // Role helpers
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isConferente() { 
      let data = get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
      return isApproved() && (data.get('category', '') in ['Conferente', 'Ventisol + Conferente'] || data.get('is_conferente', false) == true); 
    }

    // Hardened Rules Matchers - Use this for list/get to centralize
    function canViewData() {
      return isSignedIn() && (isAdmin() || (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.status == 'APPROVED'));
    }

    // Phase 2: Helper constraints
    function isValidProfile(data) {
      let requiredFields = data.keys().hasAll(['id', 'name', 'email', 'status']);
      let validTypes = data.id is string 
        && data.name is string 
        && data.email is string 
        && data.status in ['PENDING', 'APPROVED', 'REJECTED'];
      
      return requiredFields && validTypes;
    }

    // 1. Profiles
    match /profiles/{userId} {
      allow read, list: if isSignedIn() && (isOwner(userId) || canViewData());
      allow create: if isSignedIn() && (
        (isOwner(userId) && isValidProfile(incoming()) && incoming().status == 'PENDING')
        || isAdmin()
      );
      allow update: if (isSignedIn() && isOwner(userId) && incoming().diff(resource.data).affectedKeys().hasOnly(['name', 'email', 'category', 'allowed_groups']))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Operations
    function isValidOperation(data) {
      return data.keys().hasAll(['id', 'line', 'quantity', 'date'])
        && data.id is string && data.line is string && data.quantity is number;
    }
    match /operations/{opId} {
      allow read, list: if canViewData();
      allow create: if isAdmin() && isValidOperation(incoming());
      allow update: if (isAdmin() || (canViewData() && incoming().diff(resource.data).affectedKeys().hasOnly(['steps', 'progress', 'is_completed'])))
        && isValidOperation(incoming());
      allow delete: if isAdmin();
    }

    // 3. News Posts
    match /news_posts/{newsId} {
      allow read, list: if canViewData();
      allow write: if isAdmin();
    }

    // 4. Production Lines
    match /production_lines/{lineId} {
      allow read, list: if canViewData();
      allow write: if isAdmin();
    }

    // 5. Settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Suppliers & Load Types
    match /suppliers/{sId} {
      allow read, list: if canViewData();
      allow write: if isAdmin();
    }
    match /load_types/{tId} {
      allow read, list: if canViewData();
      allow write: if isAdmin();
    }

    // 7. Receipts
    match /receipts/{rId} {
      allow read, list: if canViewData();
      allow create: if (canViewData() && incoming().author_id == request.auth.uid) || isAdmin();
      allow update: if (canViewData() || isAdmin()) && (
        isAdmin() || 
        (resource.data.status != 'Concluído' && (incoming().diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at', 'updated_by_name', 'status_history', 'divergence_observation', 'divergence_photo_url'])))
      );
      allow delete: if isAdmin();
    }

    // 8. Purchase Orders
    match /purchase_orders/{pId} {
      allow read, list: if canViewData();
      allow create: if isAdmin();
      allow update: if (canViewData() || isAdmin()) && (
        isAdmin() ||
        (resource.data.status != 'Baixada' && (
          // Action: Assign (Admin handled by isAdmin() or explicit)
          (incoming().diff(resource.data).affectedKeys().hasAll(['assigned_users', 'updated_at'])) ||
          
          // Action: Separate (Ventisol & Others)
          (canViewData() && incoming().diff(resource.data).affectedKeys().hasOnly(['items', 'status', 'pis', 'observation', 'photos', 'updated_at', 'signature_url']) 
            && (incoming().status in ['Pendente', 'Separada', 'Em Separação'])) ||
          
          // Action: Confer (Conferente or Admin)
          (isConferente() && incoming().diff(resource.data).affectedKeys().hasOnly(['items', 'conferred_by_id', 'conferred_by_name', 'conferred_at', 'status', 'pis', 'observation', 'photos', 'updated_at', 'signature_url'])
            && incoming().status == 'Conferida') ||
          
          // Action: Sign (Conferente or Admin)
          (isConferente() && incoming().diff(resource.data).affectedKeys().hasOnly(['signature_url', 'is_signed', 'signed_at', 'signed_by_name', 'pis', 'observation', 'updated_at'])
            && incoming().is_signed == true)
        ))
      );
      allow delete: if isAdmin();
    }

    // 9. Transfers
    match /transfers/{tId} {
      allow read, list: if canViewData();
      allow create: if canViewData();
      allow update: if canViewData();
      allow delete: if isAdmin();
    }

  }
}
