{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "category": { "type": "string" },
        "allowed_groups": { "type": "string" },
        "is_admin": { "type": "boolean" },
        "is_super_admin": { "type": "boolean" },
        "is_viewer": { "type": "boolean" },
        "is_conferente": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "status"]
    },
    "Operation": {
      "title": "Operation",
      "description": "Production operation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "line": { "type": "string" },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "progress": { "type": "number" },
        "steps": { "type": "array", "items": { "type": "boolean" } },
        "icon_type": { "type": "string" },
        "is_completed": { "type": "boolean" },
        "is_urgente": { "type": "boolean" },
        "is_licitacao": { "type": "boolean" },
        "is_atrasada": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "NewsPost": {
      "title": "NewsPost",
      "description": "Dashboard news or alerts",
      "type": "object",
      "properties": {
        "image_url": { "type": "string" },
        "text": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "ProductionLine": {
      "title": "ProductionLine",
      "description": "Manufacturing line name",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier or Driver information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "is_driver": { "type": "boolean" }
      }
    },
    "LoadType": {
      "title": "LoadType",
      "description": "Type of cargo load",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" }
      }
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Cargo receipt log",
      "type": "object",
      "properties": {
        "load_id": { "type": "string" },
        "invoices": { "type": "array", "items": { "type": "string" } },
        "driver": { "type": "string" },
        "supplier_name": { "type": "string" },
        "load_type": { "type": "string" },
        "load_type_color": { "type": "string" },
        "status": { "type": "string" },
        "observation": { "type": "string" },
        "image_url": { "type": "string" },
        "divergence_observation": { "type": "string" },
        "divergence_photo_url": { "type": "string" },
        "author_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "updated_by_name": { "type": "string" },
        "invoice_count": { "type": "number" },
        "status_history": { "type": "object" }
      }
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "Purchase order for sorting",
      "type": "object",
      "properties": {
        "order_number": { "type": "string" },
        "supplier_name": { "type": "string" },
        "product_location": { "type": "string" },
        "date": { "type": "string" },
        "total_amount": { "type": "number" },
        "items": { "type": "array" },
        "status": { "type": "string" },
        "pdf_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "assigned_users": { "type": "array", "items": { "type": "string" } },
        "conferred_by_id": { "type": "string" },
        "conferred_by_name": { "type": "string" },
        "conferred_at": { "type": "string", "format": "date-time" },
        "is_signed": { "boolean": "boolean" },
        "signed_at": { "type": "string", "format": "date-time" },
        "signed_by_name": { "type": "string" },
        "signature_url": { "type": "string" },
        "sequence": { "type": "number" },
        "pis": { "type": "array", "items": { "type": "string" } },
        "observation": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Transfer": {
      "title": "Transfer",
      "description": "Intercompany stock transfer log",
      "type": "object",
      "properties": {
        "transfer_number": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "carrier": { "type": "string" },
        "status": { "type": "string", "enum": ["Pendente", "Conferida", "Cancelada"] },
        "items": { "type": "array" },
        "pdf_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "created_by_name": { "type": "string" },
        "conferred_by_name": { "type": "string" },
        "conferred_at": { "type": "string", "format": "date-time" },
        "device_id": { "type": "string" }
      },
      "required": ["transfer_number", "date", "origin", "destination", "items"]
    }
  },
  "firestore": {
    "/profiles/{profileId}": { "schema": "Profile", "description": "User profiles" },
    "/operations/{operationId}": { "schema": "Operation", "description": "Production operations" },
    "/news_posts/{newsId}": { "schema": "NewsPost", "description": "News and announcements" },
    "/production_lines/{lineId}": { "schema": "ProductionLine", "description": "System production lines" },
    "/settings/{settingId}": { "schema": "Setting", "description": "App-wide settings" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "List of suppliers and drivers" },
    "/load_types/{typeId}": { "schema": "LoadType", "description": "Available load types" },
    "/receipts/{receiptId}": { "schema": "Receipt", "description": "Load receipt records" },
    "/purchase_orders/{orderId}": { "schema": "PurchaseOrder", "description": "Imported purchase orders" },
    "/transfers/{transferId}": { "schema": "Transfer", "description": "Stock transfer logs" }
  }
}
