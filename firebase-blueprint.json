{
  "entities": {
    "Op": {
      "title": "Ordem de Produção",
      "description": "Dados operacionais das ordens de produção do Almoxarifado Ventisol",
      "type": "object",
      "properties": {
        "codigo": {
          "type": "string",
          "description": "Fórmula/Código interno da OP (ex: OP-VEN-501)"
        },
        "descricao": {
          "type": "string",
          "description": "Descrição detalhada do ventilador ou motor"
        },
        "quantidade": {
          "type": "number",
          "description": "Quantidade de produtos ou peças estipulados"
        },
        "status": {
          "type": "string",
          "enum": ["pendente", "separando", "concluido", "cancelada"]
        },
        "furos": {
          "type": "string",
          "description": "Configuração/sequência de furos de fixação"
        },
        "licitacao": {
          "type": "string",
          "description": "Detalhamento se pertence a licitação pública ou urgência de Palhoça/SC"
        },
        "sequencia": {
          "type": "number",
          "description": "Ordenação prioritária do dia na grade logiz"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["codigo", "descricao", "quantidade", "status", "sequencia", "createdAt", "updatedAt"]
    },
    "DockLoad": {
      "title": "Carga de Doca Intercompany",
      "description": "Controle físico de cargas e descargas na doca de Palhoça/SC",
      "type": "object",
      "properties": {
        "fornecedor": {
          "type": "string",
          "description": "Parceiro do ecossistema Ventisol"
        },
        "material": {
          "type": "string",
          "description": "Tipo de insumo carregado (ex: cobre)"
        },
        "placa": {
          "type": "string",
          "description": "Placa do cavalo mecânico do transportador"
        },
        "status": {
          "type": "string",
          "enum": ["aguardando", "descarregando", "concluido"]
        },
        "doca": {
          "type": "string",
          "description": "Local de atracação (ex: Doca 1)"
        },
        "tempoEstimado": {
          "type": "number",
          "description": "Tempo previsto em minutos de descarga"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["fornecedor", "material", "placa", "status", "doca", "tempoEstimado", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/ops/{opId}": {
      "schema": "Op",
      "description": "Coleção de controle de ordens de produção"
    },
    "/dock_loads/{loadId}": {
      "schema": "DockLoad",
      "description": "Coleção para monitoramento de docas de recebimento"
    }
  }
}
